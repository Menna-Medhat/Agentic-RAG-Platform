{
  "title": "Evaluation Quality",
  "uid": "rag-eval-quality",
  "tags": ["rag", "evaluation"],
  "timezone": "browser",
  "refresh": "1m",
  "schemaVersion": 38,
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Current Eval Score — custom_judge vs ragas",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 5 },
      "targets": [
        {
          "expr": "eval_score",
          "legendFormat": "{{judge_type}} | domain {{domain_id}}"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0, "max": 1,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": 0 },
            { "color": "yellow", "value": 0.6 },
            { "color": "green", "value": 0.8 }
          ]}
        }
      }
    },
    {
      "id": 2,
      "title": "Eval Score Over Time — by judge type",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 5 },
      "targets": [
        {
          "expr": "eval_score",
          "legendFormat": "{{judge_type}} | domain {{domain_id}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1 }
      }
    },
    {
      "id": 3,
      "title": "Evaluation Latency (p50 / p95) — by judge type",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 5, "w": 16, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(eval_latency_seconds_bucket[5m])) by (judge_type, le))",
          "legendFormat": "p50 {{judge_type}}"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(eval_latency_seconds_bucket[5m])) by (judge_type, le))",
          "legendFormat": "p95 {{judge_type}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 4,
      "title": "Judge LLM Reachability",
      "type": "stat",
      "gridPos": { "x": 16, "y": 5, "w": 8, "h": 4 },
      "targets": [
        {
          "expr": "eval_judge_reachable",
          "legendFormat": "{{judge_type}}"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ]
        }
      }
    },
    {
      "id": 5,
      "title": "Eval Failure Rate (%)",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 9, "w": 8, "h": 4 },
      "targets": [
        {
          "expr": "100 * rate(eval_requests_total{status=\"failure\"}[5m]) / rate(eval_requests_total[5m])",
          "legendFormat": "{{judge_type}} failure %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": 0 },
            { "color": "red", "value": 10 }
          ]}
        }
      }
    },
    {
      "id": 6,
      "title": "Total Evals Run (success vs failure)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 13, "w": 24, "h": 6 },
      "targets": [
        {
          "expr": "sum(increase(eval_requests_total[1h])) by (judge_type, status)",
          "legendFormat": "{{judge_type}} — {{status}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    }
  ]
}