# =============================================================================
# RAG System — Environment Configuration
# =============================================================================
# HOW TO USE:
#   1. Copy this file: `copy .env.example .env`
#   2. Fill in your actual values in the .env file
#   3. NEVER commit .env — it contains secrets and is in .gitignore
#
# Each section is marked:
#   [REQUIRED]        — must set these before running anything
#   [OPTIONAL]        — sensible defaults, change only if needed
#   [AUTO-CONFIGURED] — set automatically by run_services.py, leave as-is
# =============================================================================


# ═══════════════════════════════════════════════════════════════════════════════
# [REQUIRED] PostgreSQL — Relational Database
# ═══════════════════════════════════════════════════════════════════════════════
POSTGRES_USER=postgres
POSTGRES_PASSWORD=55555
POSTGRES_DB=domain_db
POSTGRES_PORT=5434
DATABASE_URL=postgresql+asyncpg://postgres:55555@localhost:5434/domain_db
SYNC_DATABASE_URL=postgresql://postgres:55555@localhost:5434/domain_db


# ═══════════════════════════════════════════════════════════════════════════════
# [REQUIRED] LLM: Groq API
# ═══════════════════════════════════════════════════════════════════════════════
# ⚠ ضعي هنا الـ API Key الجديد اللي عملتيه بعد ما مسحتي القديم
GROQ_API_KEY=gsk_YOUR_NEW_KEY_HERE
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile


# ═══════════════════════════════════════════════════════════════════════════════
# [OPTIONAL] LLM: Ollama
# ═══════════════════════════════════════════════════════════════════════════════
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2:3b


# ═══════════════════════════════════════════════════════════════════════════════
# [OPTIONAL] Apache AGE — Graph Database
# ═══════════════════════════════════════════════════════════════════════════════
AGE_DATABASE_DSN=postgresql://postgres:55555@localhost:5434/domain_db
AGE_GRAPH_NAME=rag_graph


# ═══════════════════════════════════════════════════════════════════════════════
# [AUTO-CONFIGURED] Redis
# ═══════════════════════════════════════════════════════════════════════════════
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0
SYNC_INGESTION=1


# ═══════════════════════════════════════════════════════════════════════════════
# [AUTO-CONFIGURED] Qdrant
# ═══════════════════════════════════════════════════════════════════════════════
QDRANT_PATH=data/qdrant


# ═══════════════════════════════════════════════════════════════════════════════
# [AUTO-CONFIGURED] Keycloak
# ═══════════════════════════════════════════════════════════════════════════════
# ✅ تم التغيير من http إلى https
KEYCLOAK_PORT=8180
KEYCLOAK_ISSUER=https://localhost:8443/realms/rag-system
KEYCLOAK_REALM_URL=https://localhost:8443/realms/rag-system
KEYCLOAK_CLIENT_ID=domain-service
KEYCLOAK_ALGORITHM=RS256
KEYCLOAK_PUBLIC_KEY=


# ═══════════════════════════════════════════════════════════════════════════════
# [AUTO-CONFIGURED] Internal Service URLs
# ═══════════════════════════════════════════════════════════════════════════════
# ✅ كلهم بقوا https على port 8000 (Caddy بيوزعهم)
DOMAIN_SERVICE_URL=https://localhost:8000
DOMAIN_SERVICE_PORT=8001
DOMAIN_SERVICE_NAME=domain-service

INGESTION_SERVICE_URL=https://localhost:8000
INGESTION_SERVICE_PORT=8002
INGESTION_SERVICE_NAME=ingestion-service

RETRIEVAL_SERVICE_URL=https://localhost:8000
RETRIEVAL_SERVICE_PORT=8003
RETRIEVAL_SERVICE_NAME=retrieval-service

GENERATION_SERVICE_URL=https://localhost:8000
GENERATION_SERVICE_PORT=8004
GENERATION_SERVICE_NAME=generation-service

EVALUATION_SERVICE_URL=https://localhost:8000
EVALUATION_SERVICE_PORT=8005
EVALUATION_SERVICE_NAME=evaluation-service


# ═══════════════════════════════════════════════════════════════════════════════
# [OPTIONAL] Security — Internal API Key
# ═══════════════════════════════════════════════════════════════════════════════
# ⚠ غيري القيمة دي — شغلي الأمر ده في الـ terminal:
# python -c "import secrets; print(secrets.token_hex(32))"
# وحطي الناتج هنا
INTERNAL_API_KEY=YOUR_GENERATED_KEY_HERE


# ═══════════════════════════════════════════════════════════════════════════════
# [OPTIONAL] Domain & RAG Defaults
# ═══════════════════════════════════════════════════════════════════════════════
SYSTEM_ADMIN_ROLE=system_admin
DEFAULT_LLM_ROUTE=api
DEFAULT_CHUNK_SIZE=512
DEFAULT_CHUNK_OVERLAP=64
DEFAULT_CONFIDENCE_THRESHOLD=0.5
MAX_SIZE_MB=50
UPLOAD_DIR=data/uploads


# ═══════════════════════════════════════════════════════════════════════════════
# [OPTIONAL] Retrieval Pipeline Tuning
# ═══════════════════════════════════════════════════════════════════════════════
TOP_K_RETRIEVE=20
TOP_K_RERANK=5
CACHE_TTL_SECONDS=3600
RERANKER_MODEL=cross-encoder/mmarco-mMiniLMv2-L12-H384-v1
RERANKER_CANDIDATE_CAP=15
TSVEC_LANGUAGE=simple
ENABLE_RERANKER=true


# ═══════════════════════════════════════════════════════════════════════════════
# [OPTIONAL] Local Model Paths
# ═══════════════════════════════════════════════════════════════════════════════
MODELS_DIR=D:\models

EMBEDDING_MODEL=D:\models\e5-small
WORKER_EMBEDDING_MODEL=D:\models\e5-small

RERANKER_MODEL=cross-encoder/mmarco-mMiniLMv2-L12-H384-v1
NER_MODEL=D:/models/gliner

PADDLEOCR_HOME=D:\models\paddleocr
TORCH_HOME=D:\models\torch

HF_HOME=D:\models\huggingface
HUGGINGFACE_HUB_CACHE=D:\models\huggingface\hub


# ═══════════════════════════════════════════════════════════════════════════════
# [OPTIONAL] OCR Pipeline Configuration
# ═══════════════════════════════════════════════════════════════════════════════
OCR_LANG=en
# OCR_LANGS=ar,en
OCR_DETECT_LANGS=ar,en,fr
OCR_CONFIDENCE_THRESHOLD=0.85


# ═══════════════════════════════════════════════════════════════════════════════
# [OPTIONAL] PaddleX / PaddleOCR
# ═══════════════════════════════════════════════════════════════════════════════
PADDLE_PDX_MODEL_SOURCE=BOS
PADDLE_PDX_DISABLE_MODEL_SOURCE_CHECK=True


# ═══════════════════════════════════════════════════════════════════════════════
# [OPTIONAL] Document Processing
# ═══════════════════════════════════════════════════════════════════════════════
ENABLE_OCR=true
ENABLE_TABLE_EXTRACTION=true


# ═══════════════════════════════════════════════════════════════════════════════
# [OPTIONAL] Evaluation Pipeline
# ═══════════════════════════════════════════════════════════════════════════════
EVALUATE_ON_GENERATION=true
EVALUATE_SYNC=true
ALLOW_MOCK_JUDGE=false
EVAL_SAMPLE_RATE=1.0


# ═══════════════════════════════════════════════════════════════════════════════
# [OPTIONAL] Retrieval Warmup & Performance
# ═══════════════════════════════════════════════════════════════════════════════
RETRIEVAL_WARMUP_ON_START=true
WARMUP_EMBEDDING=false
WARMUP_RERANKER=false
RETRIEVAL_TIMEOUT_SECONDS=300
QUERY_NER_MODE=rules_first


# ═══════════════════════════════════════════════════════════════════════════════
# [AUTO-CONFIGURED] Performance
# ═══════════════════════════════════════════════════════════════════════════════
OPENBLAS_NUM_THREADS=1
OMP_NUM_THREADS=1
MKL_NUM_THREADS=1
NUMEXPR_NUM_THREADS=1
TOKENIZERS_PARALLELISM=false
KMP_DUPLICATE_LIB_OK=TRUE