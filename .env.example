# =============================================================================
# RAG System — Environment Configuration Template
# =============================================================================
# HOW TO USE:
#   1. Copy this file: `copy .env.example .env`
#   2. Fill in your actual values in the .env file
#   3. NEVER commit .env — it contains secrets and is in .gitignore
#
# Each section is marked:
#   [REQUIRED]        — must set these before running anything
#   [OPTIONAL]        — sensible defaults, change only if needed
#   [AUTO-CONFIGURED] — set automatically by run_services.py, leave as-is
# =============================================================================


# ═══════════════════════════════════════════════════════════════════════════════
# [REQUIRED] PostgreSQL — Relational Database
# ═══════════════════════════════════════════════════════════════════════════════
# The project uses PostgreSQL 17 on port 5433.
# → Install PostgreSQL 17 from: https://www.postgresql.org/download/windows/
# → Set a password during the installation wizard; use it below.
# → Default username is 'postgres'. Do NOT change POSTGRES_USER unless you
#   created a different superuser during installation.
#
# POSTGRES_PORT: This project uses 5433 (not the default 5432) to avoid
#   conflicts with older PostgreSQL versions that may still be installed.
#   If your PostgreSQL 17 is on 5432, change all port references to 5432.
#
# DATABASE_URL: Used by FastAPI services (async SQLAlchemy via asyncpg).
#   Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<database>
#
# SYNC_DATABASE_URL: Used by Celery worker and migration scripts (sync).
#   Format: postgresql://<user>:<password>@<host>:<port>/<database>
# ───────────────────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=1234
POSTGRES_DB=domain_db
POSTGRES_PORT=5433
DATABASE_URL=postgresql+asyncpg://postgres:1234@localhost:5433/domain_db
SYNC_DATABASE_URL=postgresql://postgres:1234@localhost:5433/domain_db


# ═══════════════════════════════════════════════════════════════════════════════
# [REQUIRED] LLM: Groq API (Cloud — Primary LLM Provider)
# ═══════════════════════════════════════════════════════════════════════════════
# Groq provides fast cloud-based LLM inference. Free tier is sufficient for
# development and moderate usage.
# → Sign up at: https://console.groq.com
# → Go to: Dashboard → API Keys → Create API Key
# → The key starts with `gsk_`
#
# GROQ_BASE_URL: The OpenAI-compatible endpoint for Groq. Do not change.
#
# GROQ_MODEL: The language model used for answer generation and evaluation.
#   Options: llama-3.3-70b-versatile (default, best quality)
#            llama-3.1-8b-instant (faster, smaller)
#            mixtral-8x7b-32768 (alternative)
#   Leave as default unless you have a reason to change it.
#
# WHEN TO LEAVE GROQ_API_KEY BLANK: If you want fully offline operation,
#   leave this blank. The system will fall back to Ollama (see below).
#   Note: Relation extraction (Sprint 3 graph layer) will be skipped if blank.
# ───────────────────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_YOUR_GROQ_KEY_HERE
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile


# ═══════════════════════════════════════════════════════════════════════════════
# [OPTIONAL] LLM: Ollama (Local / Offline Fallback)
# ═══════════════════════════════════════════════════════════════════════════════
# Ollama lets you run LLMs locally without an internet connection.
# → Install Ollama: https://ollama.com/download
# → Pull the model first: ollama pull llama3.2:3b
# → Leave these as defaults if you don't plan to use Ollama.
#
# WHEN TO USE OLLAMA:
#   - You don't have a Groq API key
#   - You need fully offline/air-gapped operation
#   - You want to test with local inference
#   - Set DEFAULT_LLM_ROUTE=local in a domain config to route that domain to Ollama
# ───────────────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2:3b


# ═══════════════════════════════════════════════════════════════════════════════
# [OPTIONAL] Apache AGE — Graph Database (Sprint 3, WSL2 Only)
# ═══════════════════════════════════════════════════════════════════════════════
# Required ONLY if you enable the Graph RAG layer (Sprint 3 feature).
# This points to a PostgreSQL 17 + Apache AGE instance running inside WSL2
# on port 5433. See run_guide.md Section 5 for setup instructions.
#
# AGE_DATABASE_DSN: Full connection string to the WSL2 graph database.
#   Default password is set to '55555' by the wsl2_setup_v2.sh script.
#   Format: postgresql://<user>:<password>@localhost:<port>/<database>
#
# AGE_GRAPH_NAME: The Apache AGE graph name created by the setup script.
#   Default is 'rag_graph'. Change only if you modified the setup script.
#
# WHEN TO LEAVE THIS BLANK: If you are only using vector + BM25 retrieval
#   (Sprints 1–2), leave AGE_DATABASE_DSN blank. The system will skip all
#   graph operations gracefully. run_migration.py detects AGE availability
#   automatically and skips graph-specific SQL if not present.
# ───────────────────────────────────────────────────────────────────────────────
AGE_DATABASE_DSN=postgresql://postgres:55555@localhost:5433/domain_db
AGE_GRAPH_NAME=rag_graph


# ═══════════════════════════════════════════════════════════════════════════════
# [AUTO-CONFIGURED] Redis — Cache & Task Queue
# ═══════════════════════════════════════════════════════════════════════════════
# Redis is downloaded automatically by run_services.py on first run.
# It is extracted to tools/redis/ and started on port 6379.
# You do NOT need to install Redis manually.
#
# REDIS_URL: Connection string for Celery broker, retrieval cache, and answer cache.
#   Only change this if you are running Redis manually or in Docker on a different port.
#
# REDIS_PORT: Used internally by run_services.py to launch the portable Redis.
#   Change only if port 6379 is already occupied on your machine.
#
# SYNC_INGESTION: Set to 1 to bypass Celery and process documents synchronously
#   (useful for debugging). Set to 0 or leave blank to use async Celery pipeline.
# ───────────────────────────────────────────────────────────────────────────────
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0
SYNC_INGESTION=1


# ═══════════════════════════════════════════════════════════════════════════════
# [AUTO-CONFIGURED] Qdrant — Embedded Vector Database
# ═══════════════════════════════════════════════════════════════════════════════
# Qdrant runs embedded (in-process). No installation or separate server needed.
# The qdrant-client library opens the local directory directly.
#
# QDRANT_PATH: Where vector embeddings are stored on disk.
#   The directory is created automatically on first run.
#   Change this if you want to store vector data on a different drive.
# ───────────────────────────────────────────────────────────────────────────────
QDRANT_PATH=data/qdrant


# ═══════════════════════════════════════════════════════════════════════════════
# [AUTO-CONFIGURED] Keycloak — Identity & OIDC Provider
# ═══════════════════════════════════════════════════════════════════════════════
# Keycloak is downloaded automatically by run_services.py on first run (~150 MB).
# It is extracted to tools/keycloak/ and started on port 8180.
# Requires Java 17+: https://adoptium.net/
#
# KEYCLOAK_PORT: Port Keycloak listens on. Change only if 8180 is occupied.
#
# KEYCLOAK_ISSUER / KEYCLOAK_REALM_URL: The URL of the Keycloak realm.
#   Change only if you're running Keycloak on a different host or port.
#
# KEYCLOAK_CLIENT_ID: The OAuth2 client ID configured in the Keycloak realm.
#   Must match the realm-export.json in services/auth/. Do not change.
#
# KEYCLOAK_ALGORITHM: JWT signing algorithm. RS256 is the Keycloak default.
#
# KEYCLOAK_PUBLIC_KEY: Auto-populated by run_services.py from Keycloak's
#   JWKS endpoint on startup. Leave blank — it will be filled automatically.
#   If Keycloak is unavailable, the system falls back to dev auth mode.
# ───────────────────────────────────────────────────────────────────────────────
KEYCLOAK_PORT=8180
KEYCLOAK_ISSUER=http://localhost:8180/realms/rag-system
KEYCLOAK_REALM_URL=http://localhost:8180/realms/rag-system
KEYCLOAK_CLIENT_ID=domain-service
KEYCLOAK_ALGORITHM=RS256
KEYCLOAK_PUBLIC_KEY=


# ═══════════════════════════════════════════════════════════════════════════════
# [AUTO-CONFIGURED] Internal Service URLs
# ═══════════════════════════════════════════════════════════════════════════════
# These are the internal HTTP addresses for service-to-service communication.
# All services run on localhost. Only change if you modify run_services.py
# port assignments.
#
# DOMAIN_SERVICE_URL: Used by ingestion, retrieval, and generation services
#   to verify user permissions (/internal/check-access endpoint).
#
# *_SERVICE_PORT: Port numbers injected into each service process by run_services.py.
# ───────────────────────────────────────────────────────────────────────────────
DOMAIN_SERVICE_URL=http://localhost:8001
DOMAIN_SERVICE_PORT=8001
DOMAIN_SERVICE_NAME=domain-service

INGESTION_SERVICE_URL=http://localhost:8002
INGESTION_SERVICE_PORT=8002
INGESTION_SERVICE_NAME=ingestion-service

RETRIEVAL_SERVICE_URL=http://localhost:8003
RETRIEVAL_SERVICE_PORT=8003
RETRIEVAL_SERVICE_NAME=retrieval-service

GENERATION_SERVICE_URL=http://localhost:8004
GENERATION_SERVICE_PORT=8004
GENERATION_SERVICE_NAME=generation-service

EVALUATION_SERVICE_URL=http://localhost:8005
EVALUATION_SERVICE_PORT=8005
EVALUATION_SERVICE_NAME=evaluation-service


# ═══════════════════════════════════════════════════════════════════════════════
# [OPTIONAL] Security — Internal API Key
# ═══════════════════════════════════════════════════════════════════════════════
# Shared secret used for internal service-to-service calls on /internal/* endpoints.
# Services pass this in the X-Internal-Key HTTP header.
#
# ⚠ CHANGE THIS before any production or shared-environment deployment!
# Generate a secure value: python -c "import secrets; print(secrets.token_hex(32))"
# ───────────────────────────────────────────────────────────────────────────────
INTERNAL_API_KEY=rag-internal-dev-key-change-in-prod


# ═══════════════════════════════════════════════════════════════════════════════
# [OPTIONAL] Domain & RAG Defaults
# ═══════════════════════════════════════════════════════════════════════════════
# These control system-wide defaults for new domains. Each domain can override
# most of these values through the /domains/{id}/config API endpoint.
#
# SYSTEM_ADMIN_ROLE: The role name used for platform-wide administrator users.
#   Must match the role defined in Keycloak realm and seeded in the users table.
#
# DEFAULT_LLM_ROUTE: Which LLM backend new domains use by default.
#   'api'   → Use Groq cloud API (requires GROQ_API_KEY)
#   'local' → Use Ollama local LLM (requires Ollama installed + model pulled)
#
# DEFAULT_CHUNK_SIZE: Number of characters per text chunk during document ingestion.
#   Lower values = more, smaller chunks (better for precise retrieval)
#   Higher values = fewer, larger chunks (better for long-context answers)
#   Typical range: 256–1024
#
# DEFAULT_CHUNK_OVERLAP: Characters of overlap between adjacent chunks.
#   Prevents sentences being cut at chunk boundaries. Usually 10–15% of chunk size.
#
# DEFAULT_CONFIDENCE_THRESHOLD: Minimum retrieval score (0.0–1.0) for a chunk
#   to be included in the LLM prompt. Chunks scoring below this are dropped.
#   Higher values = more precise but potentially fewer results.
#
# MAX_SIZE_MB: Maximum document upload size in megabytes.
#   Change if you need to upload larger PDFs or documents.
#
# UPLOAD_DIR: Directory where uploaded files are saved.
#   Created automatically. Change to store uploads on a different drive.
# ───────────────────────────────────────────────────────────────────────────────
SYSTEM_ADMIN_ROLE=system_admin
DEFAULT_LLM_ROUTE=api
DEFAULT_CHUNK_SIZE=512
DEFAULT_CHUNK_OVERLAP=64
DEFAULT_CONFIDENCE_THRESHOLD=0.5
MAX_SIZE_MB=50
UPLOAD_DIR=data/uploads


# ═══════════════════════════════════════════════════════════════════════════════
# [OPTIONAL] Retrieval Pipeline Tuning
# ═══════════════════════════════════════════════════════════════════════════════
# These control the hybrid retrieval pipeline behavior.
#
# TOP_K_RETRIEVE: Number of candidate chunks fetched from vector + BM25 search
#   before reranking. Higher = more thorough but slower.
#   Typical range: 10–50. Default: 20
#
# TOP_K_RERANK: Number of final chunks sent to the LLM after cross-encoder reranking.
#   These are the actual evidence paragraphs the AI uses to write its answer.
#   Typical range: 3–10. Default: 5
#
# CACHE_TTL_SECONDS: How long Redis caches retrieval results and generated answers.
#   3600 = 1 hour. Set to 0 to disable caching (useful for testing fresh results).
#
# RERANKER_MODEL: Cross-encoder model for reranking. Downloaded on first use
#   and cached in HF_HOME. The default is multilingual and works for Arabic/English.
#   Change only if you have a domain-specific reranker model.
#
# RERANKER_CANDIDATE_CAP: Maximum number of candidates passed to the reranker.
#   Caps the reranker input to avoid excessive latency on large result sets.
#
# TSVEC_LANGUAGE: PostgreSQL full-text search dictionary for BM25 search.
#   'simple'  → No stemming, no stop-word removal (best for multilingual corpora)
#   'english' → English stemming + stop words (e.g. "running" matches "run")
#   'arabic'  → Arabic stemming (use for Arabic-only corpora)
#   Use 'simple' unless all your documents are in a single language.
#
# ENABLE_RERANKER: Set to false to disable cross-encoder reranking (faster but less
#   accurate). Useful for debugging or low-memory environments.
# ───────────────────────────────────────────────────────────────────────────────
TOP_K_RETRIEVE=20
TOP_K_RERANK=5
CACHE_TTL_SECONDS=3600
RERANKER_MODEL=cross-encoder/mmarco-mMiniLMv2-L12-H384-v1
RERANKER_CANDIDATE_CAP=15
TSVEC_LANGUAGE=simple
ENABLE_RERANKER=true


# ═══════════════════════════════════════════════════════════════════════════════
# [OPTIONAL] Local Model Paths
# ═══════════════════════════════════════════════════════════════════════════════
# If you have pre-downloaded models on a specific drive, set these paths to
# avoid re-downloading. Leave blank to use Hugging Face Hub auto-download
# (models are cached in HF_HOME).
#
# MODELS_DIR: Root directory where local model snapshots are stored.
#
# EMBEDDING_MODEL: Path to the multilingual-e5-small model directory.
#   Used by ingestion worker (for indexing) and retrieval service (for query encoding).
#   If blank, downloads from Hugging Face on first use.
#
# WORKER_EMBEDDING_MODEL: Path to embedding model for the Celery worker process.
#   Can be same as EMBEDDING_MODEL or different for worker-specific caching.
#
# RERANKER_MODEL: Path to the cross-encoder reranker model snapshot directory.
#   If set to a local path, overrides the HuggingFace model name above.
#
# NER_MODEL: Path to the GLiNER multilingual model (Sprint 3 entity extraction).
#   Used by the Celery worker for Named Entity Recognition on document chunks.
#   If blank, downloads from Hugging Face on first use.
#
# PADDLEOCR_HOME: Directory where PaddleOCR downloads its model files.
#   Default is ~/.paddlex/official_models/ — override to store on another drive.
#
# TORCH_HOME: Directory where PyTorch downloads model weights (e.g. Surya models).
#   Default is ~/.cache/torch/
#
# HF_HOME: Hugging Face Hub cache root. All downloaded models are stored here.
#   Change to redirect from C: to another drive (models can be 3–5 GB total).
#
# HUGGINGFACE_HUB_CACHE: Subfolder inside HF_HOME for hub downloads.
#   Usually set automatically from HF_HOME. Override only if you need a custom layout.
# ───────────────────────────────────────────────────────────────────────────────
MODELS_DIR=D:\huggingface_cache\models
EMBEDDING_MODEL=
WORKER_EMBEDDING_MODEL=
RERANKER_MODEL=cross-encoder/mmarco-mMiniLMv2-L12-H384-v1
NER_MODEL=
PADDLEOCR_HOME=D:\huggingface_cache\paddleocr
TORCH_HOME=D:\huggingface_cache\torch
HF_HOME=D:\huggingface_cache
HUGGINGFACE_HUB_CACHE=D:\huggingface_cache\hub


# ═══════════════════════════════════════════════════════════════════════════════
# [OPTIONAL] OCR Pipeline Configuration (Sprint 2/3)
# ═══════════════════════════════════════════════════════════════════════════════
# Controls the PaddleOCR + Surya OCR pipeline used for scanned PDFs and images.
# The worker service uses OCR when a PDF page has no native text layer or when
# the uploaded file is a PNG/JPG/JPEG image.
#
# OCR_LANG: Single-language mode — PaddleOCR loads one language-specific model.
#   Common values: 'en' (English), 'ar' (Arabic), 'fr' (French), 'ch' (Chinese)
#   See PaddleOCR docs for full list: https://paddlepaddle.github.io/PaddleOCR/
#   Default: 'en'
#   WHEN TO USE: When all your documents are in one language.
#
# OCR_LANGS (commented out by default): Comma-separated multi-language mode.
#   PaddleOCR runs once per language and keeps the result with the highest
#   average confidence score. Each language adds one extra OCR pass per page.
#   Example: OCR_LANGS=ar,en  (for mixed Arabic/English documents)
#   WHEN TO USE: When your documents contain mixed languages.
#   NOTE: OCR_LANGS takes precedence over OCR_LANG when set.
#
# OCR_DETECT_LANGS: Languages for automatic language detection (preprocessing).
#   Comma-separated list. Used for initial language detection before OCR.
#
# OCR_CONFIDENCE_THRESHOLD: PaddleOCR confidence score above which the system
#   skips Surya (the slower, more accurate fallback OCR engine).
#   Range: 0.0–1.0. Default: 0.85
#   Lower values → more Surya fallback invocations (slower but more accurate)
#   Higher values → fewer Surya calls (faster, uses PaddleOCR results more often)
# ───────────────────────────────────────────────────────────────────────────────
OCR_LANG=en
# OCR_LANGS=ar,en
OCR_DETECT_LANGS=ar,en,fr
OCR_CONFIDENCE_THRESHOLD=0.85


# ═══════════════════════════════════════════════════════════════════════════════
# [OPTIONAL] PaddleX / PaddleOCR Download Configuration
# ═══════════════════════════════════════════════════════════════════════════════
# These fix connectivity and download issues for PaddleOCR model files.
# Required for first-run model download on Windows.
#
# PADDLE_PDX_MODEL_SOURCE: Source server for downloading PaddleX models.
#   'BOS'         → Baidu Object Storage (fastest for China/most regions)
#   'HuggingFace' → Hugging Face Hub (may be slow or blocked in some regions)
#   'AIStudio'    → Baidu AI Studio (alternative)
#   Default: 'BOS' — leave as-is unless you have connectivity issues with Baidu.
#
# PADDLE_PDX_DISABLE_MODEL_SOURCE_CHECK: When True, skips checking connectivity
#   to slow model download hosts before attempting download. Speeds up startup.
# ───────────────────────────────────────────────────────────────────────────────
PADDLE_PDX_MODEL_SOURCE=BOS
PADDLE_PDX_DISABLE_MODEL_SOURCE_CHECK=True


# ═══════════════════════════════════════════════════════════════════════════════
# [OPTIONAL] Document Processing Feature Flags
# ═══════════════════════════════════════════════════════════════════════════════
# These switches enable or disable specific document processing capabilities.
#
# ENABLE_OCR: Set to false to disable OCR entirely (scanned PDFs will produce
#   empty text). Useful for debugging or if you only upload digital PDFs.
#
# ENABLE_TABLE_EXTRACTION: Set to false to skip table detection/extraction in PDFs.
#   Tables are extracted as structured text chunks by default.
# ───────────────────────────────────────────────────────────────────────────────
ENABLE_OCR=true
ENABLE_TABLE_EXTRACTION=true


# ═══════════════════════════════════════════════════════════════════════════════
# [OPTIONAL] Evaluation Pipeline Configuration
# ═══════════════════════════════════════════════════════════════════════════════
# Controls the automated evaluation system (LLM-as-judge).
# The evaluation service is only started with: python run_services.py --evaluation
#
# EVALUATE_ON_GENERATION: If true, every generated answer is automatically
#   submitted to the evaluation service for quality scoring. Adds latency.
#   Set to false for faster responses during development.
#
# EVALUATE_SYNC: If true, evaluation runs synchronously in the request path.
#   If false, evaluation is queued as a background Celery task.
#
# ALLOW_MOCK_JUDGE: If true, evaluation can use a lightweight mock judge instead
#   of calling the LLM. Useful for testing the evaluation pipeline without API calls.
#
# EVAL_SAMPLE_RATE: Fraction of queries to evaluate (0.0–1.0).
#   1.0 = evaluate every query, 0.1 = evaluate 10% of queries randomly.
#   Reduce for high-traffic scenarios to limit LLM evaluation costs.
# ───────────────────────────────────────────────────────────────────────────────
EVALUATE_ON_GENERATION=true
EVALUATE_SYNC=true
ALLOW_MOCK_JUDGE=false
EVAL_SAMPLE_RATE=1.0




# ═══════════════════════════════════════════════════════════════════════════════
# [OPTIONAL] Retrieval Warmup & Performance
# ═══════════════════════════════════════════════════════════════════════════════
# Controls model loading behavior on service startup.
#
# RETRIEVAL_WARMUP_ON_START: If true, the retrieval service loads the embedding
#   model and reranker model immediately on startup (instead of lazy-loading on
#   the first query). Makes first query faster but increases startup time/memory.
#
# WARMUP_EMBEDDING: If true, load the embedding model during warmup.
# WARMUP_RERANKER: If true, load the reranker model during warmup.
#
# RETRIEVAL_TIMEOUT_SECONDS: Maximum seconds to wait for retrieval to complete
#   before returning a timeout error. Increase for very slow machines.
#
# QUERY_NER_MODE: How Named Entity Recognition is applied to queries (Sprint 3).
#   'rules_first' → Use pattern rules first, fall back to NER model
#   'ner_only'    → Always use the NER model
#   'disabled'    → Skip query NER entirely
# ───────────────────────────────────────────────────────────────────────────────
RETRIEVAL_WARMUP_ON_START=true
WARMUP_EMBEDDING=false
WARMUP_RERANKER=false
RETRIEVAL_TIMEOUT_SECONDS=300
QUERY_NER_MODE=rules_first

TOP_K_RETRIEVE=20
TOP_K_RERANK=5
CACHE_TTL_SECONDS=3600
RERANKER_MODEL=C:\Users\asus\.cache\huggingface\hub\models--cross-encoder--mmarco-mMiniLMv2-L12-H384-v1\snapshots\1427fd652930e4ba29e8149678df786c240d8825
RERANKER_CANDIDATE_CAP=15
RERANKER_KEEP_LOADED=true
RERANKER_IDLE_TIMEOUT_SECONDS=3600
TSVEC_LANGUAGE=simple
ENABLE_RERANKER=true

# ═══════════════════════════════════════════════════════════════════════════════
# [AUTO-CONFIGURED] Performance — BLAS/OpenMP Thread Limits
# ═══════════════════════════════════════════════════════════════════════════════
# These prevent ML libraries (NumPy, PyTorch, OpenBLAS, MKL) from spawning
# too many threads, which causes CPU contention and memory pressure when
# multiple services start simultaneously on Windows.
#
# Set all to 1 to allow run_services.py to stagger service startups cleanly.
# Increase to 2–4 only if you have 16+ GB RAM and want faster inference
# at the cost of higher memory usage during startup.
#
# TOKENIZERS_PARALLELISM: Disable HuggingFace tokenizer parallelism to avoid
#   deadlocks when using Celery's forked processes.
#
# KMP_DUPLICATE_LIB_OK: Prevents crashes when multiple OpenMP DLLs are loaded
#   (common on Windows with PyTorch + PaddlePaddle both installed).
# ───────────────────────────────────────────────────────────────────────────────
OPENBLAS_NUM_THREADS=1
OMP_NUM_THREADS=1
MKL_NUM_THREADS=1
NUMEXPR_NUM_THREADS=1
TOKENIZERS_PARALLELISM=false
KMP_DUPLICATE_LIB_OK=TRUE

EVAL_SCHEDULE_MINUTES=1


PYTHONPATH=services/shared

PYTORCH_NO_CUDA_MEMORY_CACHING=1

CUDA_VISIBLE_DEVICES=-1
TORCH_DEVICE=cpu