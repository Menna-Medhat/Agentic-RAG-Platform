# =============================================================================
# RAG System — Environment Template
# Copy this file to .env and fill in your values.
# Used by run_services.py and all FastAPI services.
# NEVER commit .env — it is in .gitignore.
# =============================================================================


# ═══════════════════════════════════════════════════════════════════════════════
# REQUIRED — You MUST set these before running the project
# ═══════════════════════════════════════════════════════════════════════════════

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
# Password you set during PostgreSQL installation wizard.
# → Download & install: https://www.postgresql.org/download/windows/
# → Default username is 'postgres'. Change POSTGRES_PASSWORD to match yours.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=domain_db
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/domain_db
SYNC_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/domain_db

# ─── Groq API Key (Primary cloud LLM provider) ──────────────────────────────
# Free tier available — needed for AI answer generation.
# → Sign up at: https://console.groq.com
# → Go to: Dashboard → API Keys → Create API Key
# → Copy the key (starts with gsk_) and paste it below.
GROQ_API_KEY=gsk_YOUR_GROQ_KEY_HERE
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile


# ═══════════════════════════════════════════════════════════════════════════════
# OPTIONAL — Change only if you need specific behavior
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Ollama (Local/offline LLM fallback) ─────────────────────────────────────
# Only needed if you want to run a local LLM without internet.
# → Install Ollama: https://ollama.com/download
# → Then pull the model: ollama pull llama3.2:3b
# → Leave defaults if not using Ollama.
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2:3b

# ─── Domain defaults ─────────────────────────────────────────────────────────
# These control the default RAG behavior for new domains.
# Most users don't need to change these.
SYSTEM_ADMIN_ROLE=system_admin
DEFAULT_LLM_ROUTE=api
DEFAULT_CHUNK_SIZE=512
DEFAULT_CHUNK_OVERLAP=64
DEFAULT_CONFIDENCE_THRESHOLD=0.5
MAX_SIZE_MB=50

# ─── Retrieval tuning ────────────────────────────────────────────────────────
# TOP_K_RETRIEVE: how many chunks to fetch before reranking (higher = slower but more thorough)
# TOP_K_RERANK: how many chunks to send to the LLM after reranking
# CACHE_TTL_SECONDS: how long to cache query results (3600 = 1 hour)
# RERANKER_MODEL: cross-encoder model for reranking (auto-downloaded on first use)
TOP_K_RETRIEVE=20
TOP_K_RERANK=5
CACHE_TTL_SECONDS=3600
RERANKER_MODEL=cross-encoder/mmarco-mMiniLMv2-L12-H384-v1

# ─── Internal service-to-service auth ─────────────────────────────────────────
# Shared secret for /internal/* endpoints between services.
# ⚠ Change this to a secure random string in production!
INTERNAL_API_KEY=rag-internal-dev-key-change-in-prod


# ═══════════════════════════════════════════════════════════════════════════════
# AUTO-CONFIGURED — Don't change unless you know what you're doing
# These are set automatically by run_services.py or use sensible defaults.
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Redis (auto-downloaded by run_services.py) ──────────────────────────────
# Portable Redis is downloaded automatically on first run to tools/redis/.
# No manual install needed. If Redis is unavailable, the system gracefully
# degrades to in-memory cache and synchronous ingestion.
REDIS_URL=redis://localhost:6379/0

# ─── Qdrant (embedded — no install needed) ───────────────────────────────────
# Vector database runs in embedded mode. Storage is created automatically
# at the path below. No separate server or download required.
QDRANT_PATH=data/qdrant

# ─── Keycloak (auto-downloaded by run_services.py) ───────────────────────────
# Downloaded automatically on first run to tools/keycloak/ (~150 MB).
# Requires Java 17+ installed: https://adoptium.net/
# KEYCLOAK_PUBLIC_KEY is auto-set by run_services.py — leave blank for first run.
KEYCLOAK_ISSUER=http://localhost:8180/realms/rag-system
KEYCLOAK_REALM_URL=http://localhost:8180/realms/rag-system
KEYCLOAK_CLIENT_ID=domain-service
KEYCLOAK_ALGORITHM=RS256
KEYCLOAK_PUBLIC_KEY=

# ─── Service URLs (auto-configured by run_services.py) ──────────────────────
DOMAIN_SERVICE_URL=http://localhost:8001
INGESTION_SERVICE_URL=http://localhost:8002
RETRIEVAL_SERVICE_URL=http://localhost:8003
GENERATION_SERVICE_URL=http://localhost:8004
EVALUATION_SERVICE_URL=http://localhost:8005
UPLOAD_DIR=data/uploads

# ─── Performance (limit BLAS threads to avoid CPU contention) ────────────────
# These prevent ML libraries from spawning too many threads on multi-core CPUs.
OPENBLAS_NUM_THREADS=1
OMP_NUM_THREADS=1
MKL_NUM_THREADS=1
NUMEXPR_NUM_THREADS=1

# ─── Hugging Face Cache Location ──────────────────────────────────────────────
# Change this to redirect the downloaded models from C: to another drive (e.g. D:)
HF_HOME=D:\huggingface_cache

# ─── Apache AGE (Sprint 3 Graph RAG) ──────────────────────────────────────────
# DSN connection and graph name for PostgreSQL 17 inside WSL2 running AGE
AGE_DATABASE_DSN=postgresql://postgres:postgres@localhost:5434/domain_db
AGE_GRAPH_NAME=rag_graph

# ─── OCR Pipeline (Sprint 2/3) ────────────────────────────────────────────────
# OCR_LANG: language for PaddleOCR single-language mode (default: en)
OCR_LANG=en
# OCR_LANGS: comma-separated languages for multi-language mode (e.g., ar,en)
# OCR_LANGS=ar,en
# OCR_CONFIDENCE_THRESHOLD: PaddleOCR score above which Surya fallback is skipped
OCR_CONFIDENCE_THRESHOLD=0.85


OCR_DETECT_LANGS=ar,en,fr

