# Database (async driver)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5434/domain_db

# Keycloak
KEYCLOAK_ISSUER=http://localhost:8180/realms/rag-system,http://keycloak:8080/realms/rag-system
KEYCLOAK_REALM_URL=http://localhost:8180/realms/rag-system
KEYCLOAK_PUBLIC_KEY=
KEYCLOAK_CLIENT_ID=domain-service
KEYCLOAK_ALGORITHM=RS256
SYSTEM_ADMIN_ROLE=system_admin

# Internal service-to-service auth
INTERNAL_API_KEY=change-me-internal-key

# Service
SERVICE_PORT=8001
SERVICE_NAME=domain-service

# Default RAG config for new domains
DEFAULT_LLM_ROUTE=default
DEFAULT_CHUNK_SIZE=512
DEFAULT_CHUNK_OVERLAP=64
DEFAULT_CONFIDENCE_THRESHOLD=0.5
